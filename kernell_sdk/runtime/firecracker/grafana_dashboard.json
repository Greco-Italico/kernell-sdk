{
  "dashboard": {
    "title": "Kernell OS — Firecracker Runtime",
    "uid": "kernell-firecracker",
    "timezone": "utc",
    "refresh": "5s",
    "panels": [
      {
        "title": "Request Rate (by status)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [{"expr": "rate(kernell_requests_total[1m])", "legendFormat": "{{tenant_tier}} — {{status}}"}],
        "fieldConfig": {"defaults": {"unit": "reqps"}}
      },
      {
        "title": "p50 / p95 / p99 Latency",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {"expr": "histogram_quantile(0.50, rate(kernell_execution_latency_seconds_bucket[1m]))", "legendFormat": "p50"},
          {"expr": "histogram_quantile(0.95, rate(kernell_execution_latency_seconds_bucket[1m]))", "legendFormat": "p95"},
          {"expr": "histogram_quantile(0.99, rate(kernell_execution_latency_seconds_bucket[1m]))", "legendFormat": "p99"}
        ],
        "fieldConfig": {"defaults": {"unit": "s"}}
      },
      {
        "title": "Pool Size vs Target",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "targets": [
          {"expr": "kernell_snapshot_pool_size", "legendFormat": "Actual"},
          {"expr": "kernell_snapshot_pool_target", "legendFormat": "Target"}
        ]
      },
      {
        "title": "Inflight Requests",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 4, "x": 8, "y": 8},
        "targets": [{"expr": "kernell_inflight_requests"}],
        "fieldConfig": {"defaults": {"max": 100, "thresholds": {"steps": [
          {"value": 0, "color": "green"},
          {"value": 60, "color": "yellow"},
          {"value": 85, "color": "red"}
        ]}}}
      },
      {
        "title": "Cold Start Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 4, "x": 12, "y": 8},
        "targets": [{"expr": "rate(kernell_cold_starts_total[5m]) / rate(kernell_requests_total[5m])", "legendFormat": "Fallback %"}],
        "fieldConfig": {"defaults": {"unit": "percentunit", "thresholds": {"steps": [
          {"value": 0, "color": "green"},
          {"value": 0.05, "color": "yellow"},
          {"value": 0.15, "color": "red"}
        ]}}}
      },
      {
        "title": "Rejections",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "targets": [{"expr": "rate(kernell_rejected_total[1m])", "legendFormat": "{{reason}}"}],
        "fieldConfig": {"defaults": {"unit": "reqps"}}
      },
      {
        "title": "Credits Consumed",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [{"expr": "rate(kernell_credits_consumed_total[5m])", "legendFormat": "{{tenant_tier}}"}],
        "fieldConfig": {"defaults": {"unit": "short"}}
      },
      {
        "title": "Circuit Breaker Events",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [{"expr": "increase(kernell_circuit_breaker_opens_total[1h])", "legendFormat": "{{breaker}}"}],
        "fieldConfig": {"defaults": {"thresholds": {"steps": [
          {"value": 0, "color": "green"},
          {"value": 1, "color": "red"}
        ]}}}
      }
    ]
  }
}
